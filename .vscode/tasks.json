// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": {
				"owner": "webpack",
				"source": "ts",
				"applyTo": "allDocuments",
				"fileLocation": ["relative", "${workspaceFolder}"],
				"pattern": {
					"regexp": "^\\s*(ERROR|WARNING)\\s+in\\s+(.+)\\((\\d+),(\\d+)\\):\\s+(.+)$",
					"severity": 1,
					"file": 2,
					"line": 3,
					"column": 4,
					"message": 5
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "webpack",
					"endsPattern": "compiled (successfully|with \\d+ (error|warning))"
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "watch-tests",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build"
		},
		{
			"label": "tasks: watch-tests",
			"dependsOn": [
				"npm: watch",
				"npm: watch-tests"
			],
			"problemMatcher": []
		}
	]
}
